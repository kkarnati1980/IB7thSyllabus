# Anthropic API key — required for the tutor, quiz, flashcards, videos and mind-map endpoints.
# Get one at https://console.anthropic.com/ then copy this file to `.env.local`.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for all generation (defaults to claude-opus-4-8).
# JARVIS_MODEL=claude-opus-4-8

# Optional: secret used to sign nothing sensitive today, reserved for future token signing.
# SESSION_SECRET=change-me
